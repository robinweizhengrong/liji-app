# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# 数据库配置
DB_PATH=./database/liji.db

# 微信支付配置（待申请后填写）
WECHAT_APPID=
WECHAT_MCHID=
WECHAT_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/payments/wechat/notify

# 支付宝配置（待申请后填写）
ALIPAY_APPID=
ALIPAY_PUBLIC_KEY=
ALIPAY_PRIVATE_KEY=
